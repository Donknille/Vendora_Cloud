## Public mobile app configuration
EXPO_PUBLIC_DOMAIN=http://localhost:5000
EXPO_PUBLIC_API_URL=http://localhost:5000/api
EXPO_PUBLIC_API_SECRET=__SET_API_SHARED_SECRET__
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=__SET_SUPABASE_ANON_KEY__
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=__SET_REVENUECAT_APPLE_PUBLIC_KEY__
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=__SET_REVENUECAT_GOOGLE_PUBLIC_KEY__
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
## Server-only configuration. Keep these values out of Expo/EAS public envs.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__SET_SUPABASE_SERVICE_ROLE_KEY__
REVENUECAT_SECRET_KEY=__SET_REVENUECAT_SECRET_KEY__
REVENUECAT_ENTITLEMENT_ID=pro
DATABASE_URL=__SET_DATABASE_URL__
DIRECT_URL=__SET_DIRECT_URL__
